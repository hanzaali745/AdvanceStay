# Copy this file to .env and fill in real values. Never commit .env.

ENVIRONMENT=development
DATABASE_URL=sqlite:///./advancestay.db

# Marketplace / supplier API credentials (leave blank until authorised
# integrations are configured — connectors must not run without them).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
