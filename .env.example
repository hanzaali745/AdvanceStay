# --- App ---
APP_NAME="My Supplier"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret
DEBUG=true

# --- Database ---
# Development default (SQLite):
DATABASE_URL=sqlite:///./data/my_supplier.db
# Production example (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/my_supplier

# --- Business defaults (Settings module) ---
DEFAULT_BUDGET=0
MIN_ROI_PERCENT=20
MIN_PROFIT_AMOUNT=3
DEFAULT_SHIPPING_COST=0
DEFAULT_PACKAGING_COST=0
DEFAULT_RETURNS_ALLOWANCE_PERCENT=2
DEFAULT_MARKETPLACE_FEE_PERCENT=12.8

# --- Marketplace API credentials (integration points — leave blank until authorised) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=

# --- Notifications (integration points) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
